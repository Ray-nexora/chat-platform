# Copy to .env and adjust. Defaults match docker-compose.yml (docker compose up -d).

PORT=6000

# PostgreSQL (local Docker: postgres service)
DATABASE_URL=postgresql://chat:chat@127.0.0.1:5433/chat_platform

# Redis (local Docker: redis service)
REDIS_URL=redis://127.0.0.1:6380

# Kafka API — Redpanda in Docker exposes 19092 on localhost
KAFKA_BROKERS=127.0.0.1:19092
KAFKA_TOPIC_CHAT_EVENTS=chat.events
KAFKA_ENABLED=true

# JWT (change for anything beyond local dev)
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=7d
